{
  "name": "mirabilis-desktop",
  "version": "26.2.25",
  "description": "Mirabilis AI – Desktop App",
  "author": "Moshiko Nayman",
  "main": "main.js",
  "scripts": {
    "dev": "npx electron .",
    "verify:build": "node verify-build.js",
    "verify:release": "node verify-release.js"
  },
  "build": {
    "productName": "Mirabilis AI",
    "artifactName": "Mirabilis AI-26.2R1-S25-${arch}.${ext}",
    "appId": "com.mirabilis.ai",
    "asar": true,
    "files": [
      "main.js",
      "preload.js",
      "icons/**/*"
    ],
    "extraResources": [
      {
        "from": "backend",
        "to": "backend",
        "filter": [
          "**/*"
        ]
      },
      {
        "from": "frontend/.next/standalone",
        "to": "frontend/.next/standalone",
        "filter": [
          "**/*",
          "!frontend/.next/cache/**/*"
        ]
      }
    ],
    "mac": {
      "icon": "icons/icon.icns",
      "target": [
        {
          "target": "dmg",
          "arch": ["arm64"]
        }
      ]
    },
    "win": {
      "icon": "icons/Mirabilis.ico",
      "target": [
        { "target": "nsis", "arch": ["x64"] }
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true
    },
    "linux": {
      "icon": "icons/icon.png"
    },
    "directories": {
      "output": "dist"
    }
  },
  "devDependencies": {
    "electron": "^35.7.5",
    "electron-builder": "^25.1.8"
  }
}
