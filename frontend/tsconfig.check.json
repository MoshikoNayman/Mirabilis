{
  // Named tsconfig.check.json on purpose so Next.js never switches into TS mode
  // and `next build` stays a pure-JS build. Run on demand with: npm run typecheck.
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "allowJs": true,
    "checkJs": false,
    "noEmit": true,
    "strict": true,
    "noImplicitAny": false,
    "useUnknownInCatchVariables": false,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "forceConsistentCasingInFileNames": true,
    "types": ["node"]
  },
  "include": ["src/lib/**/*.js", "src/constants/**/*.js", "src/types.d.ts"]
}
